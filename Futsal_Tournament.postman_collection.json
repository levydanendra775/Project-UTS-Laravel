		{
			"name": "2. [Auth] Show Login Page & Extract CSRF Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Ekstraksi CSRF Token menggunakan Cheerio",
							"const responseHTML = pm.response.text();",
							"const cheerio = require('cheerio');",
							"const $ = cheerio.load(responseHTML);",
							"const csrfToken = $('input[name=\"_token\"]').val();",
							"",
							"if (csrfToken) {",
							"    pm.collectionVariables.set(\"csrf_token\", csrfToken);",
							"    console.log(\"CSRF Token berhasil disimpan:\", csrfToken);",
							"} else {",
							"    console.error(\"CSRF Token tidak ditemukan!\");",
							"}"
						],
						"type": "javascript",
						"id": "6704bbd5-f55a-4b9f-b7a4-e7c65d6c8b9d"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"login"
					]
				},
				"description": "Mengakses halaman login dan mengambil CSRF token untuk submit form berikutnya."
			},
			"response": []
		},
